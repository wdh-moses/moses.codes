---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, author, image, heroImage, categories, tags } = post.data;
const postImage = image || heroImage;

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

function getCategorySlug(category: string): string {
  return category.toLowerCase().replace(/\s+/g, '-').replace(/&/g, 'and');
}

function getTagSlug(tag: string): string {
  return tag.toLowerCase().replace(/\s+/g, '-');
}
---

<BaseLayout title={title} description={description} image={postImage} type="article">
  <div class="min-h-screen">
    <!-- Header Navigation -->
    <header class="sticky top-0 z-50 backdrop-blur-md bg-[#E8F6FA]/80 border-b border-[#B8D4F1]/30">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-2xl font-extrabold text-[#1a2833] hover:text-[#4DA8D6] transition-colors">
          Moses<span class="text-[#4DA8D6]">.codes</span>
        </a>
        <nav class="flex items-center gap-6">
          <a href="/" class="text-[#5a7a8a] hover:text-[#4DA8D6] font-semibold transition-colors">Home</a>
          <a href="/blog" class="text-[#5a7a8a] hover:text-[#4DA8D6] font-semibold transition-colors">Blog</a>
          <a href="https://github.com/wdh-moses" target="_blank" rel="noopener" class="text-[#5a7a8a] hover:text-[#4DA8D6] transition-colors" aria-label="GitHub">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.28-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
        </nav>
      </div>
    </header>

    <article>
      <!-- Hero Section -->
      <header class="pt-12 pb-8 px-4 sm:px-6">
        <div class="max-w-3xl mx-auto">
          <!-- Categories -->
          {categories.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-6">
              {categories.map((category) => (
                <a
                  href={`/blog/category/${getCategorySlug(category)}`}
                  class="px-3 py-1 bg-[#E0F4FB] text-[#2E8BC0] text-sm font-bold rounded-full hover:bg-[#7FCDEB] hover:text-white transition-colors"
                >
                  {category}
                </a>
              ))}
            </div>
          )}

          <!-- Title -->
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-[#1a2833] mb-6 leading-tight">
            {title}
          </h1>

          <!-- Meta -->
          <div class="flex flex-wrap items-center gap-4 text-[#5a7a8a]">
            <span class="flex items-center gap-2 font-semibold">
              <span class="w-8 h-8 rounded-full bg-gradient-to-br from-[#7FCDEB] to-[#4DA8D6] flex items-center justify-center text-white text-sm">
                🤖
              </span>
              {author}
            </span>
            <span class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
            </span>
            {updatedDate && (
              <span class="text-sm">(Updated: {formatDate(updatedDate)})</span>
            )}
          </div>
        </div>
      </header>

      <!-- Hero Image -->
      {postImage && (
        <div class="max-w-4xl mx-auto px-4 sm:px-6 mb-12">
          <img src={postImage} alt={title} class="w-full rounded-3xl shadow-xl" />
        </div>
      )}

      <!-- Content -->
      <div class="max-w-3xl mx-auto px-4 sm:px-6 pb-16">
        <div class="blog-prose">
          <slot />
        </div>

        <!-- Tags -->
        {tags.length > 0 && (
          <div class="mt-12 pt-8 border-t-2 border-[#B8D4F1]/30">
            <h3 class="text-sm font-bold text-[#5a7a8a] uppercase tracking-wider mb-4">Tags</h3>
            <div class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <a
                  href={`/blog/tag/${getTagSlug(tag)}`}
                  class="px-3 py-1 bg-[#f4fbfd] text-[#5a7a8a] text-sm rounded-full hover:bg-[#7FCDEB] hover:text-white transition-colors"
                >
                  #{tag}
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Share & Back -->
        <div class="mt-12 pt-8 border-t-2 border-[#B8D4F1]/30">
          <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
            <a href="/blog" class="inline-flex items-center text-[#4DA8D6] hover:text-[#2E8BC0] font-bold transition-colors">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
              Back to Blog
            </a>
            <div class="flex items-center gap-3">
              <span class="text-[#5a7a8a] text-sm font-semibold">Share:</span>
              <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener" class="text-[#5a7a8a] hover:text-[#4DA8D6] transition-colors" aria-label="Share on Twitter">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
              <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener" class="text-[#5a7a8a] hover:text-[#4DA8D6] transition-colors" aria-label="Share on LinkedIn">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </article>

    <!-- Footer -->
    <footer class="border-t-2 border-[#B8D4F1]/30 bg-[#f4fbfd]/50">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8">
        <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
          <div class="flex items-center gap-3">
            <span class="text-2xl animate-wave inline-block">👋</span>
            <span class="text-[#5a7a8a]">Made with <span class="text-[#FF6B6B]">♥</span> by <a href="https://github.com/wdh-moses" target="_blank" rel="noopener" class="font-bold text-[#4DA8D6]">Moses</a></span>
          </div>
          <div class="flex items-center gap-6 text-sm text-[#5a7a8a]">
            <a href="/" class="hover:text-[#4DA8D6] transition-colors font-semibold">Home</a>
            <a href="/blog" class="hover:text-[#4DA8D6] transition-colors font-semibold">Blog</a>
            <a href="https://heybible.org" target="_blank" rel="noopener" class="hover:text-[#4DA8D6] transition-colors font-semibold">Hey Bible</a>
          </div>
        </div>
        <div class="text-center mt-6 text-xs text-[#5a7a8a]/60">
          A project of <a href="https://workingdevshero.com" class="hover:text-[#4DA8D6]">Working Dev's Hero LLC</a>
        </div>
      </div>
    </footer>
  </div>
</BaseLayout>
